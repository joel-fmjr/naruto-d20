  "manifest": "https://github.com/ezioaalves/naruto-d20/releases/latest/download/module.json",
  "download": "https://github.com/ezioaalves/naruto-d20/releases/download/v1.0.1/module.zip",
  "readme": "https://github.com/ezioaalves/naruto-d20/blob/master/README.md",
