  "_id": "RdhmjdBmvMdODfhp",
  "name": "SANKATTO: MIE KEN SHUDO SO (THREE CUTS: TRIPLE BLADE DERVISH)",
  "type": "naruto-d20.technique",
  "img": "systems/pf1/icons/spells/fireball-sky-2.jpg",
  "_stats": {
