<div class="tab chakra" data-group="primary" data-tab="chakra">
    <!-- Chakra Resources -->
    <div class="attributes flexrow">
        <!-- Chakra Pool -->
        <div class="info-box-header health-details flexcol" style="flex: 1.5; margin-right: 5px;">
            <h3>{{localize "NarutoD20.ChakraTab.ChakraPool"}}</h3>
            <div class="info-box-joined tooltip">
                <div class="info-box current">
                    <h5>{{localize "NarutoD20.Common.Current"}}</h5>
                    <input class="value text-box direct allow-relative" type="text" name="flags.naruto-d20.chakra.pool.value" value="{{flags.naruto-d20.chakra.pool.value}}" data-dtype="Number" placeholder="0">
                </div>
                <div class="info-box temp">
                    <h5>{{localize "NarutoD20.Common.Temp"}}</h5>
                    <input class="value text-box direct allow-relative" type="text" name="flags.naruto-d20.chakra.pool.temp" value="{{flags.naruto-d20.chakra.pool.temp}}" data-dtype="Number" placeholder="0">
                </div>
                <div class="info-box maximum">
                    <h5>{{localize "NarutoD20.Common.Max"}}</h5>
                    <span class="value text-box readonly" data-naruto-tooltip="chakra.pool.max" style="cursor: default;">{{flags.naruto-d20.chakra.pool.max}}</span>
                </div>
            </div>
        </div>

        <!-- Chakra Reserve -->
        <div class="info-box-header health-details flexcol" style="flex: 1.5; margin-right: 5px; margin-left: 5px;">
            <h3 class="rollable tap-reserve-roll" style="cursor: pointer;" data-tooltip="{{localize 'NarutoD20.ChakraTab.RollTapReserves'}}">
                <i class="fas fa-dice-d20"></i> {{localize "NarutoD20.ChakraTab.ChakraReserve"}}
            </h3>
            <div class="info-box-joined tooltip">
                <div class="info-box current">
                    <h5>{{localize "NarutoD20.Common.Current"}}</h5>
                    <input class="value text-box direct allow-relative" type="text" name="flags.naruto-d20.chakra.reserve.value" value="{{flags.naruto-d20.chakra.reserve.value}}" data-dtype="Number" placeholder="0">
                </div>
                <div class="info-box maximum">
                    <h5>{{localize "NarutoD20.Common.Max"}}</h5>
                    <span class="value text-box readonly" data-naruto-tooltip="chakra.reserve.max" style="cursor: default;">{{flags.naruto-d20.chakra.reserve.max}}</span>
                </div>
            </div>
        </div>

        <!-- Empathy Points -->
        <div class="info-box-header health-details flexcol" style="flex: 1.2; margin-right: 5px; margin-left: 5px;">
            <h3>{{localize "NarutoD20.ChakraTab.EmpathyPoints"}}</h3>
            <div class="info-box-joined">
                <div class="info-box current">
                    <h5>{{localize "NarutoD20.Common.Total"}}</h5>
                    <input class="value text-box direct allow-relative" type="number" name="flags.naruto-d20.eps" value="{{flags.naruto-d20.eps}}" min="0" max="99" data-dtype="Number" placeholder="0">
                </div>
            </div>
        </div>

        <!-- Elemental Affinities -->
        <div class="info-box-header speed-details flexcol" style="flex: 2; margin-left: 5px;">
            <h3>{{localize "NarutoD20.ChakraTab.ElementalAffinities"}}</h3>
            <div class="info-box-joined">
                <div class="info-box maneuverability-details">
                    <h5>{{localize "NarutoD20.ChakraTab.Primary"}}</h5>
                    <div class="value">
                        <select name="flags.naruto-d20.chakra.nature.primary" class="live chakra-nature-select">
                            <option value="">{{localize "NarutoD20.ChakraNature.None"}}</option>
                            <option value="Fire"      {{#if (nd20-eq flags.naruto-d20.chakra.nature.primary "Fire")}}selected{{/if}}>{{localize "NarutoD20.ChakraNature.Fire"}}</option>
                            <option value="Wind"      {{#if (nd20-eq flags.naruto-d20.chakra.nature.primary "Wind")}}selected{{/if}}>{{localize "NarutoD20.ChakraNature.Wind"}}</option>
                            <option value="Lightning" {{#if (nd20-eq flags.naruto-d20.chakra.nature.primary "Lightning")}}selected{{/if}}>{{localize "NarutoD20.ChakraNature.Lightning"}}</option>
                            <option value="Earth"     {{#if (nd20-eq flags.naruto-d20.chakra.nature.primary "Earth")}}selected{{/if}}>{{localize "NarutoD20.ChakraNature.Earth"}}</option>
                            <option value="Water"     {{#if (nd20-eq flags.naruto-d20.chakra.nature.primary "Water")}}selected{{/if}}>{{localize "NarutoD20.ChakraNature.Water"}}</option>
                        </select>
                    </div>
                </div>

                {{#if (gte system.details.level.value 10)}}
                <div class="info-box maneuverability-details">
                    <h5>{{localize "NarutoD20.ChakraTab.Secondary"}}</h5>
                    <div class="value">
                        <select name="flags.naruto-d20.chakra.nature.secondary.0" class="live chakra-nature-select">
                            <option value="">{{localize "NarutoD20.ChakraNature.None"}}</option>
                            <option value="Fire"      {{#if (nd20-eq flags.naruto-d20.chakra.nature.secondary.[0] "Fire")}}selected{{/if}}>{{localize "NarutoD20.ChakraNature.Fire"}}</option>
                            <option value="Wind"      {{#if (nd20-eq flags.naruto-d20.chakra.nature.secondary.[0] "Wind")}}selected{{/if}}>{{localize "NarutoD20.ChakraNature.Wind"}}</option>
                            <option value="Lightning" {{#if (nd20-eq flags.naruto-d20.chakra.nature.secondary.[0] "Lightning")}}selected{{/if}}>{{localize "NarutoD20.ChakraNature.Lightning"}}</option>
                            <option value="Earth"     {{#if (nd20-eq flags.naruto-d20.chakra.nature.secondary.[0] "Earth")}}selected{{/if}}>{{localize "NarutoD20.ChakraNature.Earth"}}</option>
                            <option value="Water"     {{#if (nd20-eq flags.naruto-d20.chakra.nature.secondary.[0] "Water")}}selected{{/if}}>{{localize "NarutoD20.ChakraNature.Water"}}</option>
                        </select>
                    </div>
                </div>
                {{/if}}
            </div>
        </div>
    </div>

    <hr>

    <!-- Shinobi Learn Bonuses -->
    <div class="defenses flexcol">
        <h3>{{localize "NarutoD20.ChakraTab.ShinobiLearnChecks"}}</h3>
        <div class="combat-stats">

            <!-- Chakra Control -->
            <div class="info-box attribute attack cmb learn-check-box" data-naruto-tooltip="learn.ckc">
                <h5 class="rollable shinobi-roll learn-check-header" data-key="ckc" data-bonus="{{flags.naruto-d20.learn.ckc.total}}" data-label="{{localize 'NarutoD20.Skills.ckc'}}">
                    <i class="fas fa-dice-d20"></i> {{localize "NarutoD20.Skills.ckc"}}
                </h5>
                <span class="value learn-check-content">
                    <span class="learn-check-total">{{numberFormat flags.naruto-d20.learn.ckc.total sign=true}}</span>
                    <div class="learn-check-misc">
                        <input class="text-box direct allow-relative" type="text" name="flags.naruto-d20.learn.ckc.miscBonus" value="{{flags.naruto-d20.learn.ckc.miscBonus}}" data-dtype="Number" placeholder="0">
                    </div>
                </span>
            </div>

            <!-- Genjutsu -->
            <div class="info-box attribute attack cmb learn-check-box" data-naruto-tooltip="learn.gnj">
                <h5 class="rollable shinobi-roll learn-check-header" data-key="gnj" data-bonus="{{flags.naruto-d20.learn.gnj.total}}" data-label="{{localize 'NarutoD20.Skills.gnj'}}">
                    <i class="fas fa-dice-d20"></i> {{localize "NarutoD20.Skills.gnj"}}
                </h5>
                <span class="value learn-check-content">
                    <span class="learn-check-total">{{numberFormat flags.naruto-d20.learn.gnj.total sign=true}}</span>
                    <div class="learn-check-misc">
                        <input class="text-box direct allow-relative" type="text" name="flags.naruto-d20.learn.gnj.miscBonus" value="{{flags.naruto-d20.learn.gnj.miscBonus}}" data-dtype="Number" placeholder="0">
                    </div>
                </span>
            </div>

            <!-- Ninjutsu -->
            <div class="info-box attribute attack cmb learn-check-box" data-naruto-tooltip="learn.nin">
                <h5 class="rollable shinobi-roll learn-check-header" data-key="nin" data-bonus="{{flags.naruto-d20.learn.nin.total}}" data-label="{{localize 'NarutoD20.Skills.nin'}}">
                    <i class="fas fa-dice-d20"></i> {{localize "NarutoD20.Skills.nin"}}
                </h5>
                <span class="value learn-check-content">
                    <span class="learn-check-total">{{numberFormat flags.naruto-d20.learn.nin.total sign=true}}</span>
                    <div class="learn-check-misc">
                        <input class="text-box direct allow-relative" type="text" name="flags.naruto-d20.learn.nin.miscBonus" value="{{flags.naruto-d20.learn.nin.miscBonus}}" data-dtype="Number" placeholder="0">
                    </div>
                    {{#if flags.naruto-d20.learn.nin.conditional}}
                        <span class="learn-check-conditional">+{{flags.naruto-d20.learn.nin.conditional}} {{localize "NarutoD20.ChakraTab.NinjutsuConditionalTo"}} {{nd20-chakra-nature-label flags.naruto-d20.chakra.nature.primary}}</span>
                    {{/if}}
                </span>
            </div>

            <!-- Taijutsu -->
            <div class="info-box attribute attack cmb learn-check-box" data-naruto-tooltip="learn.tai">
                <h5 class="rollable shinobi-roll learn-check-header" data-key="tai" data-bonus="{{flags.naruto-d20.learn.tai.total}}" data-label="{{localize 'NarutoD20.Skills.tai'}}">
                    <i class="fas fa-dice-d20"></i> {{localize "NarutoD20.Skills.tai"}}
                </h5>
                <span class="value learn-check-content">
                    <span class="learn-check-total">{{numberFormat flags.naruto-d20.learn.tai.total sign=true}}</span>
                    <div class="learn-check-misc">
                        <input class="text-box direct allow-relative" type="text" name="flags.naruto-d20.learn.tai.miscBonus" value="{{flags.naruto-d20.learn.tai.miscBonus}}" data-dtype="Number" placeholder="0">
                    </div>
                </span>
            </div>

            <!-- Fuinjutsu -->
            <div class="info-box attribute attack cmb learn-check-box" data-naruto-tooltip="learn.fui">
                <h5 class="rollable shinobi-roll learn-check-header" data-key="fui" data-bonus="{{flags.naruto-d20.learn.fui.total}}" data-label="{{localize 'NarutoD20.Skills.fui'}}">
                    <i class="fas fa-dice-d20"></i> {{localize "NarutoD20.Skills.fui"}}
                </h5>
                <span class="value learn-check-content">
                    <span class="learn-check-total">{{numberFormat flags.naruto-d20.learn.fui.total sign=true}}</span>
                    <div class="learn-check-misc">
                        <input class="text-box direct allow-relative" type="text" name="flags.naruto-d20.learn.fui.miscBonus" value="{{flags.naruto-d20.learn.fui.miscBonus}}" data-dtype="Number" placeholder="0">
                    </div>
                </span>
            </div>

        </div>
    </div>

    <hr>

    <!-- Techniques -->
    <div class="naruto-techniques">
        <div class="techniques-header flexrow">
            <h3>{{localize "NarutoD20.ChakraTab.Techniques"}}</h3>
        </div>

        <div class="technique-disc-tabs flexrow">
            <a class="technique-filter active" data-disc="all">{{localize "NarutoD20.ChakraTab.All"}}</a>
            {{#each techniques.tabs}}
            <a class="technique-filter" data-disc="{{key}}">{{label}}</a>
            {{/each}}
        </div>

        <div class="techniques-body">
            {{#if techniques.count}}
            <div class="technique-disc-group" data-disc="all">
                {{#each techniques.allGroups}}
                <ol class="item-list technique-list">
                    <li class="flexrow item-list-header spellbook-header" data-level="{{rank}}">
                        <div class="item-name"><h3>{{localize "NarutoD20.Technique.Rank.Label"}} {{rank}}</h3></div>
                        <div class="item-detail technique-cost"><i class="fa-solid fa-fire" data-tooltip="{{localize 'NarutoD20.Technique.ChakraCost.Label'}}"></i></div>
                        <div class="item-detail item-actions"><i class="icon-pf icon-gears" data-tooltip="{{localize 'PF1.ActionPlural'}}"></i></div>
                        <div class="item-detail spell-activation"><i class="icon-pf icon-hand" data-tooltip="{{localize 'NarutoD20.ChakraTab.Activation'}}"></i></div>
                        <div class="item-detail spell-components"><i class="icon-pf icon-expense" data-tooltip="{{localize 'NarutoD20.Technique.Components.Legend'}}"></i></div>
                        <div class="item-detail spell-school"><i class="icon-pf icon-spell-book" data-tooltip="{{localize 'NarutoD20.Technique.Type.Label'}}"></i></div>
                        <div class="item-controls">
                            <a class="technique-create item-control" data-tooltip="{{localize 'NarutoD20.ChakraTab.CreateTechnique'}}" data-rank="{{rank}}"><i class="fa-solid fa-plus" inert></i></a>
                            <a class="technique-browse item-control" data-tooltip="{{localize 'NarutoD20.App.BrowseTechniques'}}" data-rank="{{rank}}"><i class="fa-solid fa-folder-plus" inert></i></a>
                        </div>
                    </li>
                    {{#each rows}}
                    <li class="item flexrow technique-row" data-item-id="{{id}}">
                        <div class="item-name">
                            <div class="item-image" style='background-image: url("{{img}}")'></div>
                            <div class="technique-name-stack">
                                <h4>{{name}}</h4>
                                {{#unless learning.effectivelyLearned}}
                                <span class="technique-learning-badge">
                                    {{learning.progress}}/{{learning.targetProgress}}
                                    {{#if learning.isFourHourBlocks}}
                                    &middot; {{learning.attemptsUsed}} {{localize "NarutoD20.Cards.Blocks"}}
                                    {{else}}
                                    &middot; {{learning.attemptsUsed}}/{{learning.maxAttempts}} {{localize "NarutoD20.ChakraTab.Attempts"}}
                                    {{/if}}
                                    {{#if learning.failureInsight}} &middot; +{{learning.failureInsight}} {{localize "NarutoD20.ChakraTab.Insight"}}{{/if}}
                                    {{#if learning.trainingBlocks}} &middot; {{learning.trainingBlocks}} {{localize "NarutoD20.ChakraTab.TrainBlocks"}}{{/if}}
                                    {{#if learning.chakraSpent}} &middot; {{learning.chakraSpent}} {{localize "NarutoD20.ChakraTab.ChakraUnit"}}{{/if}}
                                    {{#if learning.actionPointBonus}} &middot; ⚡ +{{learning.actionPointBonus}} AP{{/if}}
                                </span>
                                {{/unless}}
                            </div>
                        </div>
                        <div class="item-detail technique-cost"><span>{{chakraCost}}</span></div>
                        <div class="item-detail item-actions">
                            {{#unless learning.effectivelyLearned}}
                            <div class="item-action">
                                <a class="shinobi-technique-learn item-control action roll" data-tooltip="{{localize 'NarutoD20.ChakraTab.LearnTechnique'}}">
                                    <i class="fa-solid fa-graduation-cap" inert></i>
                                </a>
                            </div>
                            {{/unless}}
                            {{#if hasActions}}
                            <div class="item-action">
                                <a class="shinobi-technique-use item-control action roll{{#unless canUse}} disabled{{/unless}}" data-tooltip="{{localize 'NarutoD20.ChakraTab.UseTechnique'}}">
                                    <i class="fa-solid fa-dice-d20" inert></i>
                                </a>
                            </div>
                            {{/if}}
                        </div>
                        <div class="item-detail spell-activation"><span>{{activation}}</span></div>
                        <div class="item-detail spell-components"><span>{{components}}</span></div>
                        <div class="item-detail spell-school"><span>{{discipline}}</span></div>
                        <div class="item-controls">
                            <a class="shinobi-technique-open item-control" data-tooltip="{{localize 'NarutoD20.ChakraTab.OpenSheet'}}"><i class="fa-solid fa-edit" inert></i></a>
                            <a class="shinobi-technique-duplicate item-control" data-tooltip="{{localize 'NarutoD20.ChakraTab.DuplicateTechnique'}}"><i class="fa-solid fa-copy" inert></i></a>
                            <a class="shinobi-technique-delete item-control" data-tooltip="{{localize 'NarutoD20.ChakraTab.Remove'}}"><i class="fa-solid fa-trash" inert></i></a>
                        </div>
                    </li>
                    {{/each}}
                </ol>
                {{/each}}
            </div>
            {{#each techniques.tabs}}
            <div class="technique-disc-group" data-disc="{{key}}">
                {{#each groups}}
                <ol class="item-list technique-list">
                    <li class="flexrow item-list-header spellbook-header" data-level="{{rank}}">
                        <div class="item-name"><h3>{{localize "NarutoD20.Technique.Rank.Label"}} {{rank}}</h3></div>
                        <div class="item-detail technique-cost"><i class="fa-solid fa-fire" data-tooltip="{{localize 'NarutoD20.Technique.ChakraCost.Label'}}"></i></div>
                        <div class="item-detail item-actions"><i class="icon-pf icon-gears" data-tooltip="{{localize 'PF1.ActionPlural'}}"></i></div>
                        <div class="item-detail spell-activation"><i class="icon-pf icon-hand" data-tooltip="{{localize 'NarutoD20.ChakraTab.Activation'}}"></i></div>
                        <div class="item-detail spell-components"><i class="icon-pf icon-expense" data-tooltip="{{localize 'NarutoD20.Technique.Components.Legend'}}"></i></div>
                        <div class="item-detail spell-school"><i class="icon-pf icon-spell-book" data-tooltip="{{localize 'NarutoD20.Technique.Type.Label'}}"></i></div>
                        <div class="item-controls">
                            <a class="technique-create item-control" data-tooltip="{{localize 'NarutoD20.ChakraTab.CreateTechnique'}}" data-rank="{{rank}}" data-disc="{{../label}}"><i class="fa-solid fa-plus" inert></i></a>
                            <a class="technique-browse item-control" data-tooltip="{{localize 'NarutoD20.App.BrowseTechniques'}}" data-rank="{{rank}}"><i class="fa-solid fa-folder-plus" inert></i></a>
                        </div>
                    </li>
                    {{#each rows}}
                    <li class="item flexrow technique-row" data-item-id="{{id}}">
                        <div class="item-name">
                            <div class="item-image" style='background-image: url("{{img}}")'></div>
                            <div class="technique-name-stack">
                                <h4>{{name}}</h4>
                                {{#unless learning.effectivelyLearned}}
                                <span class="technique-learning-badge">
                                    {{learning.progress}}/{{learning.targetProgress}}
                                    {{#if learning.isFourHourBlocks}}
                                    &middot; {{learning.attemptsUsed}} {{localize "NarutoD20.Cards.Blocks"}}
                                    {{else}}
                                    &middot; {{learning.attemptsUsed}}/{{learning.maxAttempts}} {{localize "NarutoD20.ChakraTab.Attempts"}}
                                    {{/if}}
                                    {{#if learning.failureInsight}} &middot; +{{learning.failureInsight}} {{localize "NarutoD20.ChakraTab.Insight"}}{{/if}}
                                    {{#if learning.trainingBlocks}} &middot; {{learning.trainingBlocks}} {{localize "NarutoD20.ChakraTab.TrainBlocks"}}{{/if}}
                                    {{#if learning.chakraSpent}} &middot; {{learning.chakraSpent}} {{localize "NarutoD20.ChakraTab.ChakraUnit"}}{{/if}}
                                    {{#if learning.actionPointBonus}} &middot; ⚡ +{{learning.actionPointBonus}} AP{{/if}}
                                </span>
                                {{/unless}}
                            </div>
                        </div>
                        <div class="item-detail technique-cost"><span>{{chakraCost}}</span></div>
                        <div class="item-detail item-actions">
                            {{#unless learning.effectivelyLearned}}
                            <div class="item-action">
                                <a class="shinobi-technique-learn item-control action roll" data-tooltip="{{localize 'NarutoD20.ChakraTab.LearnTechnique'}}">
                                    <i class="fa-solid fa-graduation-cap" inert></i>
                                </a>
                            </div>
                            {{/unless}}
                            {{#if hasActions}}
                            <div class="item-action">
                                <a class="shinobi-technique-use item-control action roll{{#unless canUse}} disabled{{/unless}}" data-tooltip="{{localize 'NarutoD20.ChakraTab.UseTechnique'}}">
                                    <i class="fa-solid fa-dice-d20" inert></i>
                                </a>
                            </div>
                            {{/if}}
                        </div>
                        <div class="item-detail spell-activation"><span>{{activation}}</span></div>
                        <div class="item-detail spell-components"><span>{{components}}</span></div>
                        <div class="item-detail spell-school"><span>{{discipline}}</span></div>
                        <div class="item-controls">
                            <a class="shinobi-technique-open item-control" data-tooltip="{{localize 'NarutoD20.ChakraTab.OpenSheet'}}"><i class="fa-solid fa-edit" inert></i></a>
                            <a class="shinobi-technique-duplicate item-control" data-tooltip="{{localize 'NarutoD20.ChakraTab.DuplicateTechnique'}}"><i class="fa-solid fa-copy" inert></i></a>
                            <a class="shinobi-technique-delete item-control" data-tooltip="{{localize 'NarutoD20.ChakraTab.Remove'}}"><i class="fa-solid fa-trash" inert></i></a>
                        </div>
                    </li>
                    {{/each}}
                </ol>
                {{/each}}
            </div>
            {{/each}}
            {{else}}
            <div class="techniques-empty">
                <p>{{localize "NarutoD20.ChakraTab.EmptyTechniques"}}</p>
                <div class="item-controls">
                    <a class="technique-create item-control" data-tooltip="{{localize 'NarutoD20.ChakraTab.CreateTechnique'}}"><i class="fa-solid fa-plus" inert></i></a>
                    <a class="technique-browse item-control" data-tooltip="{{localize 'NarutoD20.App.BrowseTechniques'}}"><i class="fa-solid fa-folder-plus" inert></i></a>
                </div>
            </div>
            {{/if}}
        </div>
    </div>
</div>
