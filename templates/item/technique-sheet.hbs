{{!-- templates/item/technique-sheet.hbs --}}
{{!-- Naruto D20 Technique — V1 ItemSheet, spell-sheet grid layout --}}
<form class="{{cssClass}} flexcol" autocomplete="off" data-tooltip-class="pf1">

  {{!-- ── Header ─────────────────────────────────────────────────────── --}}
  <header class="sheet-header flexrow">
    <img class="profile" src="{{item.img}}" data-edit="img" title="{{item.name}}">

    <div class="flexcol header-details">
      <h1 class="item-name">
        <input name="name" type="text" value="{{item.name}}" placeholder="{{localize 'PF1.Name'}}">
      </h1>
      {{~> "systems/pf1/templates/internal/content-source-view.hbs"}}

      <ul class="summary flexrow">
        <li>
          <select name="system.discipline">
            {{selectOptions disciplineChoices selected=system.discipline}}
          </select>
        </li>
        <li>
          <label>{{localize "NarutoD20.Technique.Rank.Label"}}</label>
          <input type="number" name="system.rank" value="{{system.rank}}" min="1" max="15" style="width:3.5em">
        </li>
        <li>
          <select name="system.complexity">
            {{selectOptions complexityChoices selected=system.complexity}}
          </select>
        </li>
      </ul>
    </div>
  </header>

  {{!-- ── Sidebar ─────────────────────────────────────────────────────── --}}
  <section class="sidebar">
    <header>
      <h3 class="item-type">{{itemType}}</h3>
      <h4 class="discipline">{{system.discipline}}</h4>
      <h4 class="rank-line">{{localize "NarutoD20.Technique.Rank.Label"}} {{system.rank}} · {{system.complexity}}</h4>
    </header>

    <ul class="property-list stats tags">
      <h5>{{localize "NarutoD20.Technique.Type.Label"}}</h5>
      <li class="property generic-tag">Learn DC {{derived.learnDC}}</li>
      <li class="property generic-tag">Perform DC {{derived.performDC}}</li>
      <li class="property generic-tag">Threshold {{derived.skillThreshold}}</li>
      <li class="property generic-tag">Successes {{learning.requiredSuccesses}}</li>
      {{#if system.chakraResistance}}
      <li class="property generic-tag">{{localize "NarutoD20.Technique.ChakraResistance.Label"}}</li>
      {{/if}}
      {{#if learning.effectivelyLearned}}
      <li class="property generic-tag learning learned">Learned</li>
      {{#if learning.learnedViaEmpathy}}
      <li class="property generic-tag learning empathy" data-tooltip="{{localize 'NarutoD20.App.LearnWithEmpathy'}}"><i class="fa-solid fa-hand-holding-heart" inert></i> {{localize "NarutoD20.Technique.LearnedViaEmpathy"}}</li>
      {{/if}}
      {{else}}
      <li class="property generic-tag learning">Learning {{learning.progress}}/{{learning.targetProgress}}</li>
      {{/if}}
    </ul>

    {{#if hasDescriptors}}
    <ul class="property-list descriptors tags">
      <h5>{{localize "NarutoD20.Technique.Descriptors.Legend"}}</h5>
      {{#each descriptorList}}
      <li class="property generic-tag">{{this}}</li>
      {{/each}}
    </ul>
    {{/if}}

    {{#unless learning.effectivelyLearned}}
    {{#if item.actor}}
    <button type="button" class="learn-technique">
      <i class="fa-solid fa-graduation-cap" inert></i> Learn
    </button>
    {{/if}}
    {{/unless}}

    {{#if item.actor}}
    {{#if mastery.canMaster}}
    <button type="button" class="master-technique">
      <i class="fa-solid fa-star" inert></i> {{localize "NarutoD20.Technique.Master.Button"}}
    </button>
    <span class="technique-learning-badge mastery">
      {{localize "NarutoD20.Technique.Master.StepLabel"}} {{mastery.step}}→{{mastery.nextStep}}
      &middot; {{mastery.progress}}/{{mastery.targetProgress}}
      {{#if mastery.isFourHourBlocks}}
      &middot; {{mastery.attemptsUsed}} {{localize "NarutoD20.Cards.Blocks"}}
      {{else}}
      &middot; {{mastery.attemptsUsed}}/{{mastery.maxAttempts}} {{localize "NarutoD20.ChakraTab.Attempts"}}
      {{/if}}
      {{#if mastery.failureInsight}} &middot; +{{mastery.failureInsight}} {{localize "NarutoD20.ChakraTab.Insight"}}{{/if}}
      {{#if mastery.actionPointBonus}} &middot; ⚡ +{{mastery.actionPointBonus}} AP{{/if}}
    </span>
    {{else if mastery.atMax}}
    <span class="property generic-tag learning learned mastery-full" data-tooltip="{{localize 'NarutoD20.Technique.Master.MasteredHint'}}">
      <i class="fa-solid fa-star" inert></i> {{localize "NarutoD20.Technique.Master.Mastered"}}
    </span>
    {{/if}}
    {{/if}}

    {{#if isGM}}
    <fieldset class="gm-learning">
      <legend><i class="fa-solid fa-user-shield" inert></i> GM · Learning</legend>

      <label class="gm-learning__learned checkbox">
        <input type="checkbox" name="system.learning.learned" {{checked system.learning.learned}}>
        Learned
      </label>

      <div class="gm-learning__grid">
        <label class="gm-field" title="Successes accumulated so far">
          <span>Successes</span>
          <input type="number" name="system.learning.progress" value="{{learning.progress}}" min="0" step="1">
        </label>
        <label class="gm-field" title="Successes required to learn (leave blank for the rules default)">
          <span>Required</span>
          <input type="number" name="system.learning.successesOverride" value="{{learning.successesOverride}}"
                 placeholder="{{learning.derivedSuccesses}}" min="1" step="1">
        </label>
        <label class="gm-field" title="Attempts used this run">
          <span>Attempts</span>
          <input type="number" name="system.learning.attemptsUsed" value="{{learning.attemptsUsed}}" min="0" step="1">
        </label>
        <label class="gm-field" title="Failure insight bonus (0–5)">
          <span>Insight</span>
          <input type="number" name="system.learning.failureInsight" value="{{learning.failureInsight}}" min="0" max="5" step="1">
        </label>
      </div>

      <div class="learning-progress-line">
        {{learning.progress}}/{{learning.targetProgress}}
        {{#if learning.isFourHourBlocks}}
        &middot; {{learning.attemptsUsed}} blocks
        {{else}}
          {{#if learning.requiresDisciplineChoice}}
          &middot; {{localize "NarutoD20.Cards.Learn.ChooseDisciplineFirst"}}
          {{else}}
          &middot; {{learning.attemptsUsed}}/{{learning.maxAttempts}} attempts
          {{/if}}
        {{/if}}
        {{#if learning.failureInsight}} &middot; +{{learning.failureInsight}} insight{{/if}}
        {{#if learning.trainingBlocks}} &middot; {{learning.trainingBlocks}} training blocks{{/if}}
        {{#if learning.chakraSpent}} &middot; {{learning.chakraSpent}} training chakra{{/if}}
        {{#if learning.actionPointBonus}} &middot; ⚡ +{{learning.actionPointBonus}} AP{{/if}}
      </div>
      <button type="button" class="reset-learning">Reset Learning</button>
    </fieldset>

    <fieldset class="gm-learning gm-mastery">
      <legend><i class="fa-solid fa-star" inert></i> {{localize "NarutoD20.Technique.Master.GMLegend"}}</legend>

      <div class="gm-learning__grid">
        <label class="gm-field" title="Achieved mastery step — GM override (normally earned through the mastery learning process)">
          <span>{{localize "NarutoD20.Technique.MasteryStep.Label"}}</span>
          <input type="number" name="system.mastery" value="{{mastery.step}}" min="0" max="5" step="1">
        </label>
        <label class="gm-field" title="Successes accumulated toward the next step">
          <span>Successes</span>
          <input type="number" name="system.masteryLearning.progress" value="{{mastery.progress}}" min="0" step="1">
        </label>
        <label class="gm-field" title="Successes required for the next step (leave blank for the rules default)">
          <span>Required</span>
          <input type="number" name="system.masteryLearning.successesOverride" value="{{mastery.successesOverride}}"
                 placeholder="{{mastery.derivedSuccesses}}" min="1" step="1">
        </label>
        <label class="gm-field" title="Attempts used this run">
          <span>Attempts</span>
          <input type="number" name="system.masteryLearning.attemptsUsed" value="{{mastery.attemptsUsed}}" min="0" step="1">
        </label>
        <label class="gm-field" title="Failure insight bonus (0–5)">
          <span>Insight</span>
          <input type="number" name="system.masteryLearning.failureInsight" value="{{mastery.failureInsight}}" min="0" max="5" step="1">
        </label>
      </div>

      <div class="learning-progress-line">
        {{localize "NarutoD20.Technique.Master.StepLabel"}} {{mastery.step}}→{{mastery.nextStep}}
        &middot; {{mastery.progress}}/{{mastery.targetProgress}}
        {{#if mastery.isFourHourBlocks}}
        &middot; {{mastery.attemptsUsed}} blocks
        {{else}}
        &middot; {{mastery.attemptsUsed}}/{{mastery.maxAttempts}} attempts
        {{/if}}
        {{#if mastery.failureInsight}} &middot; +{{mastery.failureInsight}} insight{{/if}}
        {{#if mastery.trainingBlocks}} &middot; {{mastery.trainingBlocks}} training blocks{{/if}}
        {{#if mastery.chakraSpent}} &middot; {{mastery.chakraSpent}} training chakra{{/if}}
        {{#if mastery.actionPointBonus}} &middot; ⚡ +{{mastery.actionPointBonus}} AP{{/if}}
      </div>
      <button type="button" class="reset-mastery">{{localize "NarutoD20.Technique.Master.GMReset"}}</button>
    </fieldset>
    {{/if}}

    <label class="descriptor number">
      <span>{{localize "NarutoD20.Technique.ChakraCost.Label"}}</span>
      <input type="number" name="system.chakraCost" value="{{system.chakraCost}}" min="0">
    </label>

    {{#if hasComponents}}
    <ul class="property-list components tags">
      <h5>{{localize "NarutoD20.Technique.Components.Legend"}}</h5>
      {{#if system.compHandSeals}}    <li class="property generic-tag">{{localize "NarutoD20.Technique.Components.HandSeals.Label"}}</li>{{/if}}
      {{#if system.compHalfSeals}}    <li class="property generic-tag">{{localize "NarutoD20.Technique.Components.HalfSeals.Label"}}</li>{{/if}}
      {{#if system.compConcentration}}<li class="property generic-tag">{{localize "NarutoD20.Technique.Components.Concentration.Label"}}</li>{{/if}}
      {{#if system.compMobility}}     <li class="property generic-tag">{{localize "NarutoD20.Technique.Components.Mobility.Label"}}</li>{{/if}}
      {{#if system.compFocus}}        <li class="property generic-tag">{{localize "NarutoD20.Technique.Components.MaterialFocus.Label"}}</li>{{/if}}
      {{#if system.compEmpower}}      <li class="property generic-tag">{{localize "NarutoD20.Technique.Components.Empower.Label"}}</li>{{/if}}
      {{#if system.compMastery}}      <li class="property generic-tag">{{localize "NarutoD20.Technique.Components.Mastery.Label"}}</li>{{/if}}
      {{#if system.compExpendable}}   <li class="property generic-tag">{{localize "NarutoD20.Technique.Components.Expendable.Label"}}</li>{{/if}}
      {{#if system.compPhysical}}     <li class="property generic-tag">{{localize "NarutoD20.Technique.Components.PhysicalHealth.Label"}}</li>{{/if}}
      {{#if system.compXpCost}}       <li class="property generic-tag">{{localize "NarutoD20.Technique.Components.XpCost.Label"}}</li>{{/if}}
    </ul>
    {{/if}}

    <div class="form-group stacked sidebar-flags">
      <label class="checkbox">
        <input type="checkbox" name="system.showInQuickbar" {{checked system.showInQuickbar}}>
        {{localize "PF1.Quickbar"}}
      </label>
      <label class="checkbox">
        <input type="checkbox" name="system.showInCombat" {{checked system.showInCombat}}>
        {{localize "PF1.QuickCombat"}}
      </label>
    </div>
  </section>

  {{!-- ── Nav ────────────────────────────────────────────────────────── --}}
  <nav class="sheet-navigation tabs" data-group="primary">
    <a class="item active" data-tab="description" data-group="primary">{{localize "PF1.Description"}}</a>
    <a class="item"        data-tab="details"     data-group="primary">{{localize "PF1.Details"}}</a>
    <a class="item"        data-tab="links"       data-group="primary">{{localize "PF1.Links"}}</a>
    <a class="item"        data-tab="advanced"    data-group="primary">{{localize "PF1.Advanced"}}</a>
    <a class="item"        data-tab="automation"  data-group="primary">{{localize "NarutoD20.Automation.Tab"}}</a>
  </nav>

  {{!-- ── Body ───────────────────────────────────────────────────────── --}}
  <section class="primary-body">

    {{!-- ══════════════════════════ Description ══════════════════════════ --}}
    <div class="tab description active" data-tab="description" data-group="primary">

      <h2>{{localize "PF1.Description"}}</h2>
      <div class="description-content">
        {{editor descriptionHTML target="system.description.value" button=editable engine="prosemirror" editable=editable}}
      </div>

      <fieldset class="instructions{{#unless system.description.instructions}} placeholder{{/unless}}">
        <legend><i class="icon fa-solid fa-circle-info fa-fw"></i> {{localize "PF1.Instructions"}}</legend>
        <div class="instruction-content">
          {{editor instructionsHTML target="system.description.instructions" button=editable engine="prosemirror" editable=editable}}
        </div>
      </fieldset>
    </div>

    {{!-- ══════════════════════════ Details ══════════════════════════════ --}}
    <div class="tab details" data-tab="details" data-group="primary">

      {{!-- Actions list — matches PF1e's item-actions.hbs exactly --}}
      <div class="actions">
        <ol class="item-list action-parts">
          <li class="item-list-header flexrow">
            <div class="item-name">
              <h3>{{localize "PF1.ActionPlural"}} <span class="perform-hint">{{performHint}}</span></h3>
            </div>
            <div class="item-detail item-uses">
              <i class="icon-pf icon-battery-pack" data-tooltip="PF1.ChargePlural"></i>
            </div>
            <div class="action-controls item-controls">
              <a class="action-control add-action" data-tooltip="PF1.Add">
                <i class="fa-solid fa-plus" inert></i>
              </a>
            </div>
          </li>
          <ol class="item-list">
            {{#each actions}}
            <li class="action-part item flexrow" data-action-id="{{_id}}">
              <div class="item-name">
                <div class="item-image no-hover" style='background-image: url("{{img}}")'></div>
                <h4>{{name}}</h4>
              </div>
              <div class="item-detail item-uses flexrow"></div>
              <div class="action-controls item-controls">
                <a class="use-action{{#unless @root.canUse}} disabled{{/unless}}" data-tooltip="Use"><i class="fa-solid fa-dice-d20" inert></i></a>
                <a class="edit-action"      data-tooltip="PF1.EditAction">     <i class="fa-solid fa-edit"  inert></i></a>
                <a class="duplicate-action" data-tooltip="PF1.DuplicateAction"><i class="fa-solid fa-copy"  inert></i></a>
                <a class="delete-action"    data-tooltip="PF1.DeleteAction">   <i class="fa-solid fa-trash" inert></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </ol>
      </div>

      {{!-- Chakra Resistance — mirrors PF1e system.sr --}}
      <div class="form-group stacked spell-misc">
        <label class="checkbox">
          <input type="checkbox" name="system.chakraResistance" {{checked system.chakraResistance}}>
          {{localize "NarutoD20.Technique.ChakraResistance.Label"}}
        </label>
      </div>

      {{!-- Mastery — acts like a spell's caster level offset (see derived.masteryLevel) --}}
      <h3 class="form-header">{{localize "NarutoD20.Technique.MasteryStep.Label"}}</h3>
      <div class="form-group">
        <label>{{localize "NarutoD20.Technique.MasteryStep.Label"}}</label>
        <div class="form-fields">
          <input type="number" value="{{system.mastery}}" min="0" max="5" step="1" disabled>
        </div>
        <p class="hint">{{localize "NarutoD20.Technique.MasteryStep.Hint"}}</p>
      </div>

      {{!-- Components --}}
      <h3 class="form-header">{{localize "NarutoD20.Technique.Components.Legend"}}</h3>

      <div class="form-group stacked">
        <label class="checkbox">
          <input type="checkbox" name="system.compHandSeals" {{checked system.compHandSeals}}>
          {{localize "NarutoD20.Technique.Components.HandSeals.Label"}}
        </label>
        <label class="checkbox">
          <input type="checkbox" name="system.compHalfSeals" {{checked system.compHalfSeals}}>
          {{localize "NarutoD20.Technique.Components.HalfSeals.Label"}}
        </label>
        <label class="checkbox">
          <input type="checkbox" name="system.compConcentration" {{checked system.compConcentration}}>
          {{localize "NarutoD20.Technique.Components.Concentration.Label"}}
        </label>
        <label class="checkbox">
          <input type="checkbox" name="system.compMobility" {{checked system.compMobility}}>
          {{localize "NarutoD20.Technique.Components.Mobility.Label"}}
        </label>
        <label class="checkbox">
          <input type="checkbox" name="system.compFocus" {{checked system.compFocus}}>
          {{localize "NarutoD20.Technique.Components.MaterialFocus.Label"}}
        </label>
        <label class="checkbox">
          <input type="checkbox" name="system.compEmpower" {{checked system.compEmpower}}>
          {{localize "NarutoD20.Technique.Components.Empower.Label"}}
        </label>
        <label class="checkbox">
          <input type="checkbox" name="system.compMastery" {{checked system.compMastery}}>
          {{localize "NarutoD20.Technique.Components.Mastery.Label"}}
        </label>
        <label class="checkbox">
          <input type="checkbox" name="system.compExpendable" {{checked system.compExpendable}}>
          {{localize "NarutoD20.Technique.Components.Expendable.Label"}}
        </label>
        <label class="checkbox">
          <input type="checkbox" name="system.compPhysical" {{checked system.compPhysical}}>
          {{localize "NarutoD20.Technique.Components.PhysicalHealth.Label"}}
        </label>
        <label class="checkbox">
          <input type="checkbox" name="system.compXpCost" {{checked system.compXpCost}}>
          {{localize "NarutoD20.Technique.Components.XpCost.Label"}}
        </label>
      </div>

      {{!-- Descriptors --}}
      <h3 class="form-header">{{localize "NarutoD20.Technique.Descriptors.Legend"}}</h3>

      <div class="form-group stacked descriptor-grid">
        {{#each descriptorChoices}}
        <label class="checkbox">
          <input type="checkbox" class="descriptor-checkbox" data-descriptor="{{label}}" {{checked checked}} {{#unless @root.editable}}disabled{{/unless}}>
          {{label}}
        </label>
        {{/each}}
      </div>
    </div>

    {{!-- ══════════════════════════ Links ════════════════════════════════ --}}
    {{!-- Matches PF1e's item-links.hbs partial structure exactly --}}
    <div class="tab links" data-tab="links" data-group="primary">

      <nav class="sheet-navigation tabs" data-group="links" data-tabs-type="list">
        {{#each links.list}}
        <a class="item" data-tab="{{id}}" data-group="links">{{label}}</a>
        {{/each}}
      </nav>

      <section class="links-body">
        {{#each links.list}}
        <div class="tab" data-group="links" data-tab="{{id}}" data-drop-category="{{id}}">

          <div class="help-text">
            <i class="help-icon fa-solid fa-info-circle"></i> {{help}}
          </div>

          <table class="item-links">
            <tr>
              <th>{{localize "PF1.Item"}}</th>
              <th class="controls"></th>
            </tr>
            {{#each items}}
            <tr class="links-item{{#if broken}} broken-link{{/if}}" data-uuid="{{uuid}}" data-index="{{@index}}">
              <td class="item-name">
                <img src="{{img}}" width="24" height="24">
                <span class="name">{{#if name}}{{name}}{{else}}{{uuid}}{{/if}}</span>
                {{#if uuid}}
                <a class="source-item" data-uuid="{{uuid}}" data-tooltip="{{uuid}}">
                  <i class="fa-solid fa-book compendium-icon" inert></i>
                </a>
                {{/if}}
              </td>
              <td class="controls">
                {{#if @root.owner}}
                <a class="link-control delete-link" data-uuid="{{uuid}}" data-index="{{@index}}" data-type="{{../id}}"
                   data-tooltip="PF1.DeleteItem">
                  <i class="fa-solid fa-trash" inert></i>
                </a>
                {{/if}}
              </td>
            </tr>
            {{/each}}
          </table>
        </div>
        {{/each}}
      </section>
    </div>

    {{!-- ══════════════════════════ Advanced ═════════════════════════════ --}}
    {{!-- Matches PF1e's item-advanced.hbs structure --}}
    <div class="tab advanced" data-tab="advanced" data-group="primary">

      <div class="form-group">
        <label>{{localize "PF1.Identifier"}}</label>
        <div class="form-fields">
          <input type="text" name="system.tag" value="{{system.tag}}"
                 placeholder="{{localize 'NarutoD20.Technique.IdentifierPlaceholder'}}"
                 pattern="[a-zA-Z0-9_-]+">
        </div>
      </div>

      <div class="flexcol">
        <div class="flags">
          <h3 class="form-header">{{localize "PF1.Flags"}}</h3>

          {{!-- Boolean Flags — entry-selector opens PF1e's modal --}}
          <div class="form-group">
            <div class="form-fields boolean-flags">
              <div class="data-selector">
                <a class="entry-selector"
                   data-for="system.flags.boolean"
                   data-flag="true"
                   data-boolean="true"
                   data-fields="PF1.Name"
                   data-dtypes="String"
                   data-title="PF1.FlagsBoolean">
                  <i class="fa-solid fa-edit" inert></i>
                </a>
                <label>{{localize "PF1.FlagsBoolean"}}</label>
              </div>
              <div class="tag-list flexrow">
                {{#each flags.boolean as |value key|}}
                <span class="tag">{{key}}</span>
                {{/each}}
              </div>
            </div>
          </div>

          {{!-- Dictionary Flags — entry-selector opens PF1e's modal --}}
          <div class="form-group">
            <div class="form-fields dictionary-flags">
              <div class="data-selector">
                <a class="entry-selector"
                   data-for="system.flags.dictionary"
                   data-flag="true"
                   data-fields="PF1.Name;PF1.Value"
                   data-dtypes="String;String"
                   data-title="PF1.FlagsDictionary">
                  <i class="fa-solid fa-edit" inert></i>
                </a>
                <label>{{localize "PF1.FlagsDictionary"}}</label>
              </div>
            </div>

            {{#if flags.dictionary}}
            <table>
              <thead>
                <tr>
                  <th>{{localize "PF1.Name"}}</th>
                  <th>{{localize "PF1.Value"}}</th>
                </tr>
              </thead>
              <tbody>
                {{#each flags.dictionary as |value key|}}
                <tr data-tooltip="@dFlags.{{@root.system.tag}}.{{key}}">
                  <td>{{key}}</td>
                  <td>{{value}}</td>
                </tr>
                {{/each}}
              </tbody>
            </table>
            {{/if}}
          </div>
        </div>

        {{!-- Script Calls --}}
        {{#if scriptCalls}}
        <div class="script-calls">
          <h3 class="form-header">{{localize "PF1.ScriptCalls.Name"}}</h3>

          {{#each scriptCalls}}
          <ol class="item-list" {{#each dataset as |value|}}data-{{@key}}="{{value}}"{{/each}}>
            <li class="item-list-header flexrow">
              <div class="item-name">
                {{#if tooltip}}
                <i class="fa-solid fa-info fa-fw item-info" data-tooltip="{{tooltip}}"></i>
                {{/if}}
                <h3>{{name}}</h3>
              </div>

              {{#if @root.isGM}}
              <div class="item-detail item-hidden">
                <i class="fa-solid fa-eye-slash" data-tooltip="PF1.Hidden"></i>
              </div>
              {{/if}}

              <div class="item-controls">
                {{#if @root.owner}}
                <a class="item-control item-create" data-tooltip="PF1.ScriptCalls.Create">
                  <i class="fa-solid fa-plus" inert></i>
                </a>
                {{/if}}
              </div>
            </li>

            <ol class="item-list">
              {{#each items}}
              <li class="item flexrow" data-item-id="{{id}}">
                <div class="item-name">
                  <div class="item-image no-hover" style='background-image: url("{{img}}")'></div>
                  <h4>{{name}}</h4>
                </div>

                {{#if @root.isGM}}
                <div class="item-detail item-hidden">
                  <a class="item-control item-hide">
                    <span class="hidden-icon">
                      <i class="fa-solid {{#if hidden}}fa-check is-visible{{else}}fa-times is-hidden{{/if}} fa-fw" inert></i>
                    </span>
                  </a>
                </div>
                {{/if}}

                <div class="item-controls">
                  <a class="item-control item-edit" data-tooltip="PF1.EditItem"><i class="fa-solid fa-edit" inert></i></a>
                  {{#if @root.owner}}
                  <a class="item-control item-delete" data-tooltip="PF1.DeleteItem"><i class="fa-solid fa-trash" inert></i></a>
                  {{/if}}
                </div>
              </li>
              {{/each}}
            </ol>
          </ol>
          {{/each}}
        </div>
        {{/if}}

        {{!-- Tags --}}
        <h3 class="form-header">{{localize "PF1.Tags"}}</h3>
        <div class="form-group">
          <div class="tag-list flexrow">
            {{#each tagList}}
            <span class="tag" data-tag="{{this}}">
              {{this}}<a class="delete-tag" data-tag="{{this}}">×</a>
            </span>
            {{/each}}
            <input type="text" class="add-tag-input" placeholder="{{localize 'NarutoD20.Technique.AddTagPlaceholder'}}">
          </div>
        </div>
      </div>
    </div>

    {{!-- ══════════════════════════ Automation ══════════════════════════ --}}
    <div class="tab automation" data-tab="automation" data-group="primary">

      <h3 class="form-header">{{localize "NarutoD20.Automation.Header"}}</h3>

      <div class="form-group">
        <label class="checkbox">
          <input type="checkbox" name="system.automation.enabled" {{checked system.automation.enabled}}>
          {{localize "NarutoD20.Automation.Enabled.Label"}}
        </label>
      </div>

      <div class="form-group">
        <label class="checkbox">
          <input type="checkbox" name="system.automation.stanceMode" {{checked system.automation.stanceMode}}>
          {{localize "NarutoD20.Automation.StanceMode.Label"}}
        </label>
      </div>

      <div class="form-group">
        <label>{{localize "NarutoD20.Automation.TargetMode.Label"}}</label>
        <select name="system.automation.targetMode">
          {{selectOptions buffTargetModeChoices selected=system.automation.targetMode}}
        </select>
      </div>

    </div>

  </section>
</form>
