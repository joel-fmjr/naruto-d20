      "_key": "chakra-pool",
      "_classes": ["shinobi", "genin"],
      "_level": 1,
      "name": "Chakra Pool",
      "type": "feat",
      "img": "modules/naruto-d20/icons/feat-chakra-pool.webp",
      "system": {
        "description": {
          "value": "<p>At 1st level, a shinobi gains a <b>Chakra Pool</b> equal to their character level + Wisdom modifier (minimum 1). The Chakra Pool is spent to perform techniques and recovers after 8 hours of rest.</p><p>The shinobi can also expend 1 Chakra as a swift action to gain a +1 bonus on their next technique perform check.</p>"
        },
        "subType": "classFeature",
        "traitType": "class feature",
        "traitCategory": "chakra",
        "abilityType": "su",
        "associations": {
