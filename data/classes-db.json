    {
      "_key": "learn-techniques",
      "_classes": ["shinobi", "genin"],
      "_level": 1,
      "name": "Learn Techniques",
      "type": "feat",
      "img": "modules/naruto-d20/icons/feat-learn-techniques.webp",
      "system": {
        "description": {
          "value": "<p>A shinobi learns techniques (jutsus) through dedicated training and study. To learn a technique, the shinobi must succeed on a <b>Learn Check</b> using the skill associated with the technique's discipline (Chakra Control, Ninjutsu, Taijutsu, Genjutsu, or Fuinjutsu) against a DC equal to the technique's Rank × 2 + 10.</p><p>Techniques are stored in the shinobi's chakra tab and can be performed during combat or exploration.</p>"
        },
