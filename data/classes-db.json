{
  "_meta": {
    "format": "naruto-d20-classes-db",
    "version": "1.0.0",
    "description": "Database template for Naruto D20 classes and class features. Each entry maps directly to a PF1e Item document. Import via Foundry's compendium JSON import or the naruto-d20 import script.",
    "fieldNotes": {
      "class._key":           "Local slug used by classFeatures._classes[] to link features before UUIDs are known",
      "class.progression":    "Level → feature keys table; used by an import script to write system.links.classAssociations on the created class item",
      "classFeature._key":    "Local slug referenced by class.progression[].features[]",
      "classFeature._classes":"Array of class _key values this feature belongs to (resolved to UUIDs on import)",
      "classFeature._level":  "The class level at which this feature is granted (used to build classAssociations)",
      "abilityType":          "na=none, ex=extraordinary, su=supernatural, sp=spell-like",
      "bab":                  "low=½ lvl, med=¾ lvl, high=1× lvl",
      "savingThrows.*.value": "low or high",
      "changes[].operator":   "add, set, script",
      "changes[].target":     "buff target key, e.g. 'chakraPool', 'learnCkc', or PF1e standard keys",
      "changes[].type":       "untyped, base, enh, dodge, morale, insight, sacred, profane, luck, competence, circumstance, size, trait"
    }
  },

